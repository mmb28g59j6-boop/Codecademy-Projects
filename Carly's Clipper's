hairstyles = ["bouffant", "pixie", "dreadlocks", "crew", "bowl", "bob", "mohawk", "flattop"]

prices = [30, 25, 40, 20, 20, 35, 50, 35]

last_week = [2, 3, 5, 8, 4, 4, 6, 2]

total_price = 0
# adds prices together and puts total in total_price

for price in prices:
  total_price += price
  print(total_price)

# takes total price and divides it by how many numbers are inside prices

average_price = total_price / len(prices)
print(average_price) 

# subtract 5 from all prices and put them in new_prices

new_prices = [price - 5 for price in prices]
print(new_prices)

total_revenue = 0

# Loops through 'prices' and muliplies them by last 'week' then put total in Total Revenue

for (i) in range(len(hairstyles)):
  total_revenue += prices[i] * last_week[i]
print(total_revenue)
print("Total Revenue:", + total_revenue)

average_daily_revenue = total_revenue/7
print(average_daily_revenue)


cuts_under_30 = [hairstyles[i] for i in range(len(new_prices)) if new_prices[i] < 30]
print("Cuts under 30:", cuts_under_30)
